rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── 輔助函數（避免重複邏輯）─────────────────────
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/counselors/$(request.auth.uid))
        && get(/databases/$(database)/documents/counselors/$(request.auth.uid)).data.isSuperAdmin == true;
    }
    function isCounselor() {
      return exists(/databases/$(database)/documents/counselors/$(request.auth.uid))
        && get(/databases/$(database)/documents/counselors/$(request.auth.uid)).data.isActive != false
        && get(/databases/$(database)/documents/counselors/$(request.auth.uid)).data.isDeleted != true;
    }
    // ── 使用者個人資料 ────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
    // ── 測驗結果 ──────────────────────────────────────
    match /assessments/{docId} {
      allow create: if true;
      // ── 讀取（Phase 9.2 / A2）：get 與 list 分離 ──
      // 單筆 get 鎖定：本人 / Super Admin / 綁定且未撤銷授權的諮詢師。
      // 堵住「任意登入者拿 docId 直接讀他人報告」與「被撤銷授權的諮詢師
      // 仍能從 report.html?id= 讀取」兩個漏洞（counselorAccess 現在 DB 層生效）。
      // 註：counselorAccess 欄位不存在時視為授權（null != false 為 true），
      //     符合「undefined/true 皆授權，僅 false 撤銷」的資料契約。
      allow get: if request.auth != null && (
        request.auth.uid == resource.data.uid
        || isSuperAdmin()
        || (isCounselor()
            && resource.data.assignedCounselorUid == request.auth.uid
            && resource.data.counselorAccess != false)
      );
      // 查詢（list）維持登入可用：admin 後台 Super Admin 全表查詢、
      // 一般諮詢師 where assignedCounselorUid、timeline/dashboard where uid 都靠 list。
      // ⚠️ 殘留風險：list 未逐筆落實 counselorAccess 過濾（Firestore 規則非過濾器，
      //    需查詢端 where 對齊 + counselorAccess 全面布林化才能收緊）。
      //    目前 list 結果仍由前端過濾，列為後續 backlog。
      allow list: if request.auth != null;
      // 本人可更新；諮詢師可寫入 assignedCounselorUid
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid
        || isCounselor()
      );
      // ⭐ 7.6 新增：本人或 Super Admin 可刪除
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.uid
        || isSuperAdmin()
      );
    }
    // ── 測驗草稿（自動存檔）──────────────────────────
    match /user_progress/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && docId.matches(request.auth.uid + "_.*");
    }
    // ── 諮詢師備註 ────────────────────────────────────
    match /counselor_notes/{docId} {
      allow read, write: if request.auth != null && isCounselor();
    }
    // ── 白板功能已於 2026-07-20 依使用者決策全面移除 ──────
    // 原有 whiteboard_sessions（含子集合）與 whiteboard_active 兩個集合的
    // 規則為 `if request.auth != null`，任何登入者皆可讀寫任意 session，
    // 並可經由結束流程取得他人評測報告的存取權（SEC-002 / SEC-005，皆 P0）。
    // 功能移除後不再保留任何規則 —— 未列出的路徑一律拒絕存取，
    // 因此殘留資料即使仍在資料庫中也無法被前端讀寫。
    // 既有文件的實際清理另行處理（需使用者授權後執行）。
    // ── 意見回饋（基礎建設⑤，2026-07-16）──────────────
    // 任何人皆可送出回饋（含未登入訪客）；只讀權限保留給 Super Admin（未來後台）。
    // 客戶端不可讀他人回饋、不可改/刪，避免濫用；create 加基本欄位驗證擋灌爆。
    match /feedback/{docId} {
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000;
      allow read: if request.auth != null && isSuperAdmin();
      allow update, delete: if false;
    }
    // ── 諮詢師管理 ────────────────────────────────────
    match /counselors/{docId} {
      // 任何登入者可讀（isCounselor 函數需要查詢）
      allow read: if request.auth != null;
      // 建立 / 更新：Super Admin 或本人（pending 遷移用）
      allow create, update: if request.auth != null && (
        isSuperAdmin()
        || request.auth.uid == docId
      );
      // 刪除：Super Admin、本人文件、或本人的 pending 文件（email 對應）
      allow delete: if request.auth != null && (
        isSuperAdmin()
        || request.auth.uid == docId
        || resource.data.email == request.auth.token.email
      );
    }
  }
}
